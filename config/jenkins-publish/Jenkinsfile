#!groovy

@Library('common') _

pipeline {
    agent {
        label 'matrikkelen'
    }

    tools {
        jdk 'Java 17 Latest'
    }

    parameters {
        string(name: 'SUFFIX', defaultValue: '.0', description: 'Subversjon for bygg.')
    }

    environment {
        MAVEN_PUBLISH = credentials('MAVEN_DEPLOY_RELEASES')
    }

    stages {
        stage('Prepare') {
            steps {
                sh "./gradlew clean assemble --refresh-dependencies -Dsuffix=${params.SUFFIX}"
            }
        }
        stage('Publish release') {
            steps {
                sh "./gradlew publish -Dsuffix=${params.SUFFIX}"
            }
        }
    }

    options {
        buildDiscarder(logRotator(artifactNumToKeepStr: '30', numToKeepStr: '90'))
        skipStagesAfterUnstable()
        timeout(time: 60, unit: 'MINUTES')
        timestamps()
    }

    post {
        unsuccessful {
            pushBuildFeed()
        }
    }
}
